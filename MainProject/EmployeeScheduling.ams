		}
		Section DB_Demand {
			Comment: "Database mapping for demand data";
			DatabaseTable db_readDemands {
				Comment: "Database table mapping for demand data";
				DataSource: sp_def_connectionString;
				TableName: "demand";
				Mapping: {
					"restaurant_id" -->i_rest,
					"skill_id"      -->i_sk,
					"shift_id"      -->i_sh,
					"demand"        -->p_demand
				}
			}
			Procedure pr_readDemandDB {
				Comment: "Read demand data from the database";
				Body: {
					! Empty the demand data
					empty Demand;
					
					! Read from the database table
					read from table db_readDemands;
				}
			}
			Procedure pr_writeDemandDB {
				Comment: "Write demand data to the database";
				Body: {
					! Write demand data to the table
					write p_demand(i_rest, i_sh, i_sk)
					    to table db_readDemands in dense mode;
				}
			}
		}
	}
	Section Unit_Test {
		Comment: "Section for unit testing functionalities";
		Procedure pr_loadUnitTestData {
			Comment: "Load unit test data";
			Body: {
				! Clear main model data
				empty Main_EmployeeScheduling;
				
				! Load case file for unit test
				CaseFileLoad("unit-test/unit-test.data");
			}
		}
	}
