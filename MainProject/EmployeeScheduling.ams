			Procedure pr_readEmployeeSkillDB {
				Comment: "Read employee skills data from the database";
				Body: {
					! Empty the employee skill data
					empty Employee_Skill;
					
					! Read from the database table
					read from table db_readEmployeeSkills;
				}
			}
			Procedure pr_writeEmployeeSkillDB {
				Comment: "Write employee skills data to the database";
				Body: {
					! Write employee skill data to the table
