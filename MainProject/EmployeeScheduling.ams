			}
		}
		Procedure PostMainInitialization {
			Comment: "Post main initialization procedure";
			Body: {
				! Clear UI selection parameters
				ep_selectedRestaurant := '';
				ep_selectedEmployee := '';
			}
		}
		Procedure MainExecution {
			Comment: "Main execution procedure";
			Body: {
				! Empty main execution body
			}
		}
		Procedure PreMainTermination {
			Comment: "Pre main termination procedure";
			Body: {
				! Return 1 to allow termination
				return 1 ;
			}
		}
		Procedure MainTermination {
			Comment: "Main termination procedure";
			Body: {
				! Return 1 to allow termination
				return 1;
			}
		}
	}
