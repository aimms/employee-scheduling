	Section Database_Connection {
		Comment: "Database connection parameters and procedures";
		StringParameter sp_def_connectionString {
			Comment: "Definition of the database connection string";
			Definition: {
				SQLCreateConnectionString (
					DatabaseInterface              :  'odbc',
					DriverName                     :  sp_def_driverName,
					ServerName                     :  "", 
					DatabaseName                   :  "inputs.db", !The path of your database
					UserId                         :  "", 
					Password                       :  "", 
					AdditionalConnectionParameters :  "") ;
			}
		}
		StringParameter sp_def_driverName {
			Comment: "Name of the ODBC driver for SQLite";
			Definition: {
				if pro::GetPROEndPoint() or not ProjectDeveloperMode() then
				    "SQLite3"
				else 
				    "SQLite3 ODBC Driver"    
				endif;
			}
		}
		Procedure pr_readAll {
			Comment: "Read all tables from the database";
			Body: {
				! check if connection holds
				p_loc_testConnection := TestDataSource(sp_def_connectionString);
				
				if p_loc_testConnection then
				    pr_readSkillDB;
				    pr_readShiftDB;
				    pr_readEmployeeDB;
				    pr_readRestaurantDB;
				    pr_readEmployeeShiftsDB;
				    pr_readEmployeeSkillDB;
				    pr_readDemandDB;
				
				else    
				    s_loc_actions := {'Cancel'};
				
				    webui::RequestPerformWebUIDialog(
				                title   :  "Minimal Requirements", 
				                message :  "Please install 'SQLite3 ODBC Driver' and try again.", 
				                actions :  s_loc_actions, 
				                onDone  :  'webui::NoOp1');
				endif;
			}
			Parameter p_loc_testConnection {
				Comment: "Local parameter to test DB connection";
			}
			StringParameter sp_loc_driverName {
				Comment: "Local string parameter for driver name";
			}
			Set s_loc_actions {
				Comment: "Local actions set for webui dialog";
			}
		}
		Procedure pr_writeAll {
			Comment: "Write all data to the database";
			Body: {
				! check if connection holds
				p_loc_testConnection := TestDataSource(sp_def_connectionString);
				
				if p_loc_testConnection then
				    pr_writeSkillDB;
				    pr_writeShiftDB;
				    pr_writeEmployeeDB;
				    pr_writeRestaurantDB;
				    pr_writeEmployeeShiftsDB;
				    pr_writeEmployeeSkillDB;
				    pr_writeDemandDB;
				
				else 
				    s_loc_actions := {'Cancel'};
				
				    webui::RequestPerformWebUIDialog(
				            title   :  "Minimal Requirements", 
				            message :  "Please install 'SQLite3 ODBC Driver' and try again.", 
				            actions :  s_loc_actions, 
				            onDone  :  'webui::NoOp1');
				endif;
			}
			Parameter p_loc_testConnection {
				Comment: "Local parameter to test DB connection";
			}
			StringParameter sp_loc_driverName {
				Comment: "Local string parameter for driver name";
			}
			Set s_loc_actions {
				Comment: "Local actions set for webui dialog";
			}
		}
		Section DB_Skills {
			Comment: "Database mapping for skills";
			DatabaseTable db_readSkills {
				Comment: "Database table mapping for skills";
				DataSource: sp_def_connectionString;
				TableName: "skill";
				Mapping: {
					"id"     -->i_sk,
					"active" -->p_activeSkill( i_sk )
				}
			}
			Procedure pr_readSkillDB {
				Comment: "Read skills data from the database";
				Body: {
					! Empty the skills data
					empty Skills;
					
					! Read from the database table
					read from table db_readSkills;
				}
			}
			Procedure pr_writeSkillDB {
				Comment: "Write skills data to the database";
				Body: {
					! Write skills data to the table
					write p_activeSkill(i_sk)
					    to table db_readSkills in dense mode;
				}
			}
		}
		Section DB_Shifts {
			Comment: "Database mapping for shifts";
			DatabaseTable db_readShifts {
				Comment: "Database table mapping for shifts";
				DataSource: sp_def_connectionString;
				TableName: "shift";
				Mapping: {
					"id"         -->i_sh,
					"active"     -->p_activeShift(i_sh),
					"start_time" -->p_startTime(i_sh),
					"duration" -->p_duration(i_sh)
				}
			}
			Procedure pr_readShiftDB {
				Comment: "Read shifts data from the database";
				Body: {
					! Empty the shifts data
					empty Shifts;
					! Read from the database table
					read from table db_readShifts;
				}
			}
			Procedure pr_writeShiftDB {
				Comment: "Write shifts data to the database";
				Body: {
					! Write shifts data to the table
					write p_activeShift(i_sh), 
					        p_startTime(i_sh),
					        p_duration(i_sh)
					    to table db_readShifts in dense mode;
				}
			}
		}
		Section DB_Employee {
			Comment: "Database mapping for employees";
			DatabaseTable db_readEmployees {
				Comment: "Database table mapping for employees";
				DataSource: sp_def_connectionString;
				TableName: "employee";
				Mapping: {
					"id"          -->i_empl,
					"active"      -->p_activeEmployee(i_empl),
					"description" -->sp_employeeDescription( i_empl )
				}
			}
			Procedure pr_readEmployeeDB {
				Comment: "Read employee data from the database";
				Body: {
					! Empty the employee data
					empty Employees;
					
					! Read from the database table
					read from table db_readEmployees;
				}
			}
			Procedure pr_writeEmployeeDB {
				Comment: "Write employee data to the database";
				Body: {
					! Write employee data to the table
					write sp_employeeDescription(i_empl), 
					        p_activeEmployee(i_empl) 
					    to table db_readEmployees in dense mode;
				}
			}
		}
		Section DB_Restaurant {
			Comment: "Database mapping for restaurants";
